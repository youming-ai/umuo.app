// ============================================================================
// VERSION AND METADATA
// ============================================================================

export const ERROR_CLASSIFICATION_VERSION = "1.0.0";
export const ERROR_CLASSIFICATION_BUILD_DATE = new Date().toISOString();
export const ERROR_MIDDLEWARE_VERSION = "1.0.0";
export const ERROR_MIDDLEWARE_BUILD_DATE = new Date().toISOString();
export const ERROR_ANALYTICS_VERSION = "1.0.0";
export const ERROR_ANALYTICS_BUILD_DATE = new Date().toISOString();
export const TROUBLESHOOTING_SYSTEM_VERSION = "1.0.0";
export const TROUBLESHOOTING_SYSTEM_BUILD_DATE = new Date().toISOString();

/**
 * System information and health check
 */
export function getSystemInfo() {
  return {
    version: ERROR_CLASSIFICATION_VERSION,
    buildDate: ERROR_CLASSIFICATION_BUILD_DATE,
    classifier: ErrorClassifier.getInstance(),
    capabilities: {
      classification: true,
      patternRecognition: true,
      clustering: true,
      prediction: true,
      recovery: true,
      monitoring: true,
      testing: true,
      troubleshooting: true,
    },
    components: {
      errorClassification: {
        version: ERROR_CLASSIFICATION_VERSION,
        available: true,
      },
      errorMiddleware: {
        version: ERROR_MIDDLEWARE_VERSION,
        available: true,
      },
      errorAnalytics: {
        version: ERROR_ANALYTICS_VERSION,
        available: true,
      },
      troubleshootingSystem: {
        version: TROUBLESHOOTING_SYSTEM_VERSION,
        available: true,
        features: {
          symptomChecking: true,
          guidedResolution: true,
          knowledgeBase: true,
          mobileSupport: true,
          analytics: true,
          contentManagement: true,
          errorIntegration: true,
          reactComponents: true,
        },
      },
    },
  };
}

// ============================================================================
// DEVELOPMENT HELPERS
// ============================================================================

/**
 * Development helper to enable debug mode
 */
export function enableDebugMode(): void {
  if (typeof window !== "undefined") {
    (window as any).__ERROR_CLASSIFICATION_DEBUG__ = true;
  }
}

/**
 * Check if debug mode is enabled
 */
export function isDebugMode(): boolean {
  return (
    typeof window !== "undefined" &&
    (window as any).__ERROR_CLASSIFICATION_DEBUG__ === true
  );
}

/**
 * Development helper to log debug information
 */
export function debugLog(message: string, data?: any): void {
  if (isDebugMode()) {
    console.log(`[ErrorClassification] ${message}`, data);
  }
}

/**
 * Development helper to clear all error data
 */
export function clearAllErrorData(): void {
  const classifier = ErrorClassifier.getInstance();
  classifier.clearHistory();

  debugLog("All error data cleared");
}
