{
  "name": "umuo-app",
  "version": "1.0.0",
  "description": "A language learning application focused on shadowing practice with AI-powered audio transcription",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:dev": "node scripts/deploy/build/build-dev.js",
    "build:staging": "node scripts/deploy/build/build-staging.js",
    "build:prod": "node scripts/deploy/build/build-prod.js",
    "build:optimize": "node scripts/deploy/build/build-optimizer.js",
    "start": "next start",
    "deploy": "node scripts/deploy.js --environment=production --deploy",
    "deploy:preview": "vercel",
    "deploy:staging": "node scripts/deploy.js --environment=staging --deploy",
    "deploy:dev": "node scripts/deploy.js --environment=development",
    "deploy:dry-run": "node scripts/deploy.js --dry-run --analyze",
    "lint": "biome check .",
    "format": "biome format . --write",
    "type-check": "tsc --noEmit",
    "ci:build": "pnpm install --frozen-lockfile && pnpm lint && pnpm type-check && pnpm build",
    "ci:deploy": "pnpm ci:build && node scripts/deploy.js --environment=production --deploy --analyze",
    "ci:deploy-staging": "pnpm ci:build && node scripts/deploy.js --environment=staging --deploy --analyze",
    "clean": "rm -rf .next node_modules/.cache deployment-info",
    "bundle:analyze": "node scripts/deploy/build/bundle-analyzer.js",
    "bundle:optimize": "node scripts/deploy/build/build-optimizer.js",
    "test": "vitest",
    "test:performance": "vitest run --config vitest.config.performance.ts",
    "test:performance:watch": "vitest --config vitest.config.performance.ts",
    "test:performance:ci": "vitest run --config vitest.config.performance.ts --reporter=json --outputFile=test-results/performance.json",
    "test:performance:ui": "vitest --config vitest.config.performance.ts --ui",
    "test:performance:coverage": "vitest run --config vitest.config.performance.ts --coverage",
    "performance-test": "node scripts/performance-test.js",
    "performance-test:ci": "node scripts/performance-test.js --fail-on-error --generate-report",
    "performance-monitor": "node scripts/performance-monitor.js",
    "deployment:validate": "node scripts/deploy.js --dry-run --analyze",
    "deployment:report": "node scripts/deploy.js --dry-run --deploy",
    "deployment:monitor": "node scripts/deploy/monitoring/deployment-monitor.js"
  },
  "keywords": [
    "language-learning",
    "transcription",
    "audio",
    "ai",
    "education"
  ],
  "author": "umuo.app Team",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.2.0",
    "groq-sdk": "^0.34.0",
    "lucide-react": "^0.543.0",
    "next": "^15.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.7",
    "web-vitals": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.0",
    "typescript": "^5.9.2",
    "vitest": "^1.0.0"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d"
}
