# Required Configuration
GROQ_API_KEY=your_groq_api_key_here

# Application URL (automatically set during deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Transcription Configuration
TRANSCRIPTION_TIMEOUT_MS=180000
TRANSCRIPTION_RETRY_COUNT=2
TRANSCRIPTION_MAX_CONCURRENCY=2

# Enhanced Groq SDK Configuration for Optimization
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_MS=25000
GROQ_MAX_RETRIES=3
GROQ_CHUNK_SIZE_THRESHOLD_MB=15
GROQ_MAX_CHUNK_DURATION_SEC=300
GROQ_MIN_CHUNK_DURATION_SEC=30
GROQ_OVERLAP_DURATION_SEC=5

# Performance Monitoring Configuration
GROQ_PERFORMANCE_MONITORING=true
GROQ_METRICS_RETENTION_HOURS=24

# Progress Tracking Configuration
PROGRESS_UPDATE_INTERVAL_MS=2000
PROGRESS_CONNECTION_TYPE=sse
PROGRESS_FALLBACK_TO_POLLING=true

# Mobile Optimization Configuration
MOBILE_TOUCH_TARGET_MIN_SIZE=44
MOBILE_TOUCH_TARGET_OPTIMAL_SIZE=48
MOBILE_MIN_SCREEN_WIDTH=320

# Performance Optimization
TRANSCRIPTION_SPEED_IMPROVEMENT_TARGET=0.4
UI_RESPONSE_TIME_TARGET_MS=300
PROGRESS_UPDATE_FREQUENCY_MS=2000

# Memory Management
AUDIO_MEMORY_CACHE_SIZE_MB=100
AUDIO_MEMORY_CLEANUP_INTERVAL_MIN=5
