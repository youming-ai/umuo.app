{
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "noVar": "error",
        "useConst": "error",
        "noShoutyConstants": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUndeclaredVariables": "error"
      },
      "complexity": {
        "noExtraBooleanCast": "error"
      }
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "files": {
    "includes": ["src/**/*", "*.{ts,tsx,js,jsx}"],
    "ignore": ["src/**/*.d.ts", "node_modules/**", "dist/**", ".next/**"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingComma": "es5"
    }
  },
  "typescript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingComma": "es5"
    }
  }
}
